# Base de Dados MySQL
DATABASE_URL=mysql://user:senha@localhost:3306/informatica

# Autenticação JWT
JWT_SECRET=minha_chave_super_secreta

# Servidor SMTP para emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=teuemail@gmail.com
SMTP_PASS=senha_app

# Google Calendar API (OAuth2)
GOOGLE_CLIENT_ID=id_do_google_cloud
GOOGLE_CLIENT_SECRET=secret_do_google_cloud
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Web Push Notifications
VAPID_PUBLIC_KEY=chave_publica_push
VAPID_PRIVATE_KEY=chave_privada_push

# URL do Frontend
CLIENT_URL=http://localhost:5173

# Porta do servidor
PORT=3000